# KudiEscrow Backend Configuration
# Copy this file to .env and update values as needed

# Server port (default: 3000)
PORT=3000

# Postgres connection string
# For local Docker development (see docker-compose.yml):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kudiescrow

# For Render deployment:
# DATABASE_URL=postgres://[user]:[password]@[host]:[port]/[database]

# Session configuration (optional)
# SESSION_COOKIE_SECRET=your-secret-key

# Development admin bootstrap (used by seed/reset flow)
# NODE_ENV=development
# ALLOW_DEV_RESET=true
# ADMIN_NAME=Platform Admin
# ADMIN_EMAIL=admin@kudiescrow.local
# ADMIN_PASSWORD=ChangeMe123!
# ADMIN_ROLE=admin
